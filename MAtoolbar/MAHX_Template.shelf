  <tool name="selected name" label="selected name" icon="hicon:/SVGIcons.index?BUTTONS_auto_save.svg">
    <script scriptType="python"><![CDATA[import hou
from PySide6 import QtWidgets, QtCore, QtGui

def create_attribute_split_tool():
    # æ£æ¥æ¯å¦éä¸­èç¹
    selected_nodes = hou.selectedNodes()
    if not selected_nodes:
        hou.ui.displayMessage("è¯·åéæ©ä¸ä¸ªèç¹ï¼", severity=hou.severityType.Error)
        return
    
    node = selected_nodes[0] #éä¸­çç¬¬ä¸ä¸ªèç¹
    
    # æ£æ¥æ¯å¦ä¸ºå ä½èç¹
    if node.type().category().name() != "Sop":
        hou.ui.displayMessage("è¯·éæ©å ä½èç¹ï¼", severity=hou.severityType.Error)
        return
    
    # è·åå ä½ä½
    geo = node.geometry()
    if not geo:
        hou.ui.displayMessage("èç¹æ²¡æå ä½ä½ï¼", severity=hou.severityType.Error)
        return
    
    # èªå¨æ£æ¥å±çº§å±æ§å¯ç¨æ§
    def has_valid_attributes(level):
        try:
            if level == "Point":
                return any(attr.dataType().name() in ["Int", "String"] for attr in geo.pointAttribs())
            elif level == "Primitive":
                return any(attr.dataType().name() in ["Int", "String"] for attr in geo.primAttribs())
            return False
        except:
            return False
    
    # èªå¨éæ©å¯ç¨çå±çº§
    current_level = "Primitive"
    if not has_valid_attributes(current_level):
        # å°è¯åæ¢å°Pointå±çº§
        current_level = "Point"
        if not has_valid_attributes(current_level):
            hou.ui.displayMessage("èç¹æ²¡æç¬¦åæ¡ä»¶çæ´æ°æå­ç¬¦ä¸²å±æ§ï¼", severity=hou.severityType.Error)
            return
    
    # åå»ºå¯¹è¯æ¡
    dialog = QtWidgets.QDialog(hou.qt.mainWindow())
    dialog.setWindowTitle("Houdini å±æ§åç¦»å·¥å·")
    dialog.setMinimumSize(400, 200)
    
    # åå»ºå¸å±
    layout = QtWidgets.QVBoxLayout(dialog)
    
    # æ·»å èç¹ä¿¡æ¯
    node_info = QtWidgets.QLabel(f"å½åèç¹: {node.name()}")
    layout.addWidget(node_info)
    
    # æ·»å å±æ§å±çº§éæ©
    level_label = QtWidgets.QLabel("è¯·éæ©å±æ§å±çº§:")
    layout.addWidget(level_label)
    
    level_combo = QtWidgets.QComboBox()
    level_combo.addItems(["Point", "Primitive"])
    
    # è®¾ç½®å½åå±çº§ï¼åºäºèªå¨æ£æµï¼
    if current_level == "Point":
        level_combo.setCurrentIndex(0)
    else:
        level_combo.setCurrentIndex(1)
    
    layout.addWidget(level_combo)
    
    # æ·»å å±æ§åéæ©
    attr_label = QtWidgets.QLabel("è¯·éæ©å±æ§å:")
    layout.addWidget(attr_label)
    
    attr_combo = QtWidgets.QComboBox()
    layout.addWidget(attr_combo)
    
    # å½æ°ï¼æ´æ°å±æ§åè¡¨ï¼åªåå«æ´æ°åå­ç¬¦ä¸²ç±»åï¼
    def update_attributes():
        level = level_combo.currentText()
        attr_combo.clear()
        
        try:
            attributes = []
            
            if level == "Point":
                # è·åç¹å±æ§
                point_attribs = geo.pointAttribs()
                for attr in point_attribs:
                    # åªä¿çæ´æ°åå­ç¬¦ä¸²ç±»åå±æ§
                    if attr.dataType().name() in ["Int", "String"]:
                        attributes.append(attr.name())
            
            elif level == "Primitive":
                # è·åå¾åå±æ§
                prim_attribs = geo.primAttribs()
                for attr in prim_attribs:
                    # åªä¿çæ´æ°åå­ç¬¦ä¸²ç±»åå±æ§
                    if attr.dataType().name() in ["Int", "String"]:
                        attributes.append(attr.name())
            
            # æå­æ¯é¡ºåºæåº
            attributes.sort()
            attr_combo.addItems(attributes)
            
            # å¦ææ²¡æå±æ§ï¼å°è¯èªå¨åæ¢å±çº§
            if not attributes:
                new_level = "Point" if level == "Primitive" else "Primitive"
                if new_level == "Point":
                    level_combo.setCurrentIndex(0)
                else:
                    level_combo.setCurrentIndex(1)
                
                # éå½è°ç¨æ´æ°å±æ§
                update_attributes()
                
        except Exception as e:
            # æå°éè¯¯ä¿¡æ¯ï¼ä½ä¸ä¸­æ­æ§è¡
            print(f"è·åå±æ§æ¶åºé: {str(e)}")
    
    # åå§æ´æ°åè¿æ¥ä¿¡å·
    update_attributes()
    level_combo.currentTextChanged.connect(update_attributes)
    
    # æ·»å æé®
    button_box = QtWidgets.QDialogButtonBox(
        QtWidgets.QDialogButtonBox.Ok | QtWidgets.QDialogButtonBox.Cancel
    )
    button_box.accepted.connect(dialog.accept)
    button_box.rejected.connect(dialog.reject)
    layout.addWidget(button_box)
    
    # æ¾ç¤ºå¯¹è¯æ¡
    if dialog.exec_():
        level = level_combo.currentText()
        attribute = attr_combo.currentText()
        
        # å¦æå±æ§åä¸ºç©ºï¼è¯´ææ²¡æç¬¦åæ¡ä»¶çå±æ§
        if not attribute:
            hou.ui.displayMessage("æ²¡ææ¾å°ç¬¦åæ¡ä»¶çå±æ§ï¼", severity=hou.severityType.Warning)
            return
        
        # æ¶éå±æ§å¼
        unique_values = set()
        
        try:
            if level == "Point":
                # ç¡®ä¿å±æ§å­å¨
                if geo.findPointAttrib(attribute):
                    for point in geo.points():
                        try:
                            value = point.attribValue(attribute)
                            unique_values.add(value)
                        except:
                            print(f"æ æ³è·åç¹ {point.number()} çå±æ§ '{attribute}' å¼")
            
            elif level == "Primitive":
                # ç¡®ä¿å±æ§å­å¨
                if geo.findPrimAttrib(attribute):
                    for prim in geo.prims():
                        try:
                            value = prim.attribValue(attribute)
                            unique_values.add(value)
                        except:
                            print(f"æ æ³è·åå¾å {prim.number()} çå±æ§ '{attribute}' å¼")            
        
        except Exception as e:
            hou.ui.displayMessage(f"è·åå±æ§å¼å¤±è´¥: {str(e)}", severity=hou.severityType.Warning)
            return
        
        # å¦ææ²¡ææ¾å°ä»»ä½å±æ§å¼
        if not unique_values:
            hou.ui.displayMessage("æ²¡ææ¾å°ä»»ä½å±æ§å¼ï¼", severity=hou.severityType.Warning)
            return
        
        # è·ååå§èç¹ä½ç½®ä½ä¸ºå¸å±åºå
        base_position = node.position()
        
        # è®¡ç®æ°èç¹ä½ç½®ï¼åä¸åç§»2ä¸ªåä½
        new_position = [
            base_position[0],  # Xåæ ä¸å
            base_position[1] - 2  # Yåæ åä¸ç§»å¨2ä¸ªåä½
        ]
        
        # åå»ºæ¤éç»
        with hou.undos.group("å±æ§åç¦»å·¥å·æä½"):
            # åå»ºä¸ä¸ªå
            mycolor = hou.Vector3(0.451,0.369,0.796)
            parent_node = node.parent()
            subnet = parent_node.createNode("subnet","Cryptomatte")
            subnet.setPosition([node.position()[0],node.position()[1]-1])
            subnet.setColor(hou.Color(mycolor))
            subnet.setFirstInput(node)
            subnet_0= subnet.indirectInputs()[0] # è·ååéé¢çç¬¬ä¸ä¸ªæ¥å£çèç¹
            # åå»º blast èç¹
            for i, value in enumerate(unique_values):
                # åå»º blast èç¹
                blast = subnet.createNode("blast", f"blast_{attribute}_{i}")
                
                # è®¾ç½®èç¹é¢è²ä¸ºçº¯é»è²
                blast.setColor(hou.Color(0, 0, 0))
                
                # è¿æ¥å°åéé¢çç¬¬ä¸ä¸ªæ¥å£çèç¹
                blast.setInput(0, subnet_0)
                
                # è®¾ç½®ä½ç½® - æ¨ªåæå
                blast.setPosition([
                    new_position[0] + i * 2,  # æ¨ªåé´é2ä¸ªåä½
                    new_position[1] - i * 0.4 
                ])
                
                # è®¾ç½® blast èç¹åæ°
                blast.parm("group").set(f"@{attribute}={value}")
                
                # æ ¹æ®å±çº§è®¾ç½®åç»ç±»å
                if level == "Point":
                    blast.parm("grouptype").set(3)  # ç¹
                elif level == "Primitive":
                    blast.parm("grouptype").set(4)  # å¾å
                
                blast.parm("negate").set(1)  # åè½¬éæ©ï¼ä¿çå¹éçï¼
                
                # æ·»å æ³¨éè¯´æ
                blast.setComment(f"ä¿ç {attribute} = {value}")
            hou.ui.setStatusMessage(f"âåç¦»æåï¼å±{i}ä¸ªå¯¹è±¡", hou.severityType.ImportantMessage)
            # èªå¨å¸å±èç¹
            #parent.layoutChildren()

# å¨Houdiniä¸­è°ç¨
create_attribute_split_tool()]]></script>
