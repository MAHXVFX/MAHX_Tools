l   "Reflections"                  parm {                     name    "sepparm14"                     label   "sepparm14"                     type    separator                     default { "" }                 }                 parm {                     name    "wavereflecint"                     label   "Reflect Intensity"                     type    float                     default { "1" }                     disablewhen "{ refl_enable == 0 }"                     range   { 0 1 }                     parmtag { "parmvop" "1" }                     parmtag { "shaderparmcontexts" "surface" }                 }                 parm {                     name    "oceanspeccolor"                     label   "Reflect Color"                     type    color                     size    3                     default { "1" "1" "1" }                     disablewhen "{ refl_enable == 0 }"                     range   { 0 1 }                     parmtag { "parmvop" "1" }                     parmtag { "shaderparmcontexts" "surface" }                 }                 parm {                     name    "oceanspecrough"                     label   "Reflect Roughness"                     type    float                     default { "0" }                     disablewhen "{ refl_enable == 0 }"                     range   { 0 1 }                     parmtag { "parmvop" "1" }                     parmtag { "shaderparmcontexts" "surface" }                 }                 parm {                     name    "oceanspecmin"                     label   "Reflect Minimum"                     type    float                     default { "0" }                     disablewhen "{ refl_enable == 0 } { fres_enable == 0 }"                     range   { 0 1 }                     parmtag { "parmvop" "1" }                     parmtag { "shaderparmcontexts" "surface" }                 }             }              group {                 name    "wavediffuse_2"                 label   "Refractions"                  parm {                     name    "sepparm8"                     label   "sepparm8"                     type    separator                     default { "" }                 }                 parm {                     name    "oceanrefract"                     label   "Refract Intensity"                     type    float                     default { "0.5" }                     disablewhen "{ refr_enable == 0 }"                     range   { 0 1 }                     parmtag { "parmvop" "1" }                     parmtag { "shaderparmcontexts" "surface" }                 }                 parm {                     name    "oceanrefractcolor"                     label   "Refract Color"                     type    color                     size    3                     default { "0.6192" "0.70992" "0.72" }                     disablewhen "{ refr_enable == 0 }"                     range   { 0 1 }                     parmtag { "parmvop" "1" }                     parmtag { "shaderparmcontexts" "surface" }                 }                 parm {                     name    "oceanrefractrough"                     label   "Refract Roughness"                     type    float                     default { "0.05" }                     disablewhen "{ refr_enable == 0 }"                     range   { 0 1 }                     parmtag { "parmvop" "1" }                     parmtag { "shaderparmcontexts" "surface" }                 }                 parm {                     name    "oceanrefractmin"                     label   "Refract Minimum"                     type    float                     default { "0" }                     disablewhen "{ refr_enable == 0 } { fres_enable == 0 }"                     range   { 0 1 }                     parmtag { "parmvop" "1" }                     parmtag { "shaderparmcontexts" "surface" }                 }             }          }          group {             name    "waves_1"             label   "Foam"              parm {    