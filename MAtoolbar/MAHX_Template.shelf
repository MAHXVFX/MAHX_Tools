opset -d off -r off -h off -f off -y off -t off -l off -s off -u off -F on -c on -e on -b off $_obj_guidedoceanlayer_initial_polyextrude1
opexprlanguage -s hscript $_obj_guidedoceanlayer_initial_polyextrude1
