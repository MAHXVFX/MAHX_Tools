 a single file. -->

  <toolshelf name="MAHX_Template" label="MAHX Template">
    <memberTool name="RBD_Small"/>
    <memberTool name="geo_nodes_script"/>
    <memberTool name="QT bian su"/>
    <memberTool name="selected name"/>
    <memberTool name="Cam images"/>
    <memberTool name="OpenHipPath"/>
    <memberTool name="Wet_Tex"/>
