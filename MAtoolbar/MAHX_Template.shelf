opparm $_obj_GEO_MODLE_subnet7_instancepath snippet ( 'int myname = floor(rand(i@id+4153)*25);\ns@instancepath = "$HIP/geo/GEO_RBD_small/GEO_RBD_small"+itoa(myname)+".bgeo.sc";\n@pscale *=chf("P_multiply");\n\n' ) P_multiply ( 1 )
