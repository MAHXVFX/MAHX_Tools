 specified in object space"             }             parmtag { "parmvop" "1" }             parmtag { "shaderparmcontexts" "" }         }         parm {             name    "vm_redice"             label   "Re-Dice Displacements"             type    toggle             default { "off" }             help    "With extreme displacement, it\'s possible to get micro-polygons which are stretched far out of shape. Turning re-dicing on will cause the geometry to be re-measured after a trial displacement, to get a much better estimate of the actual size of the displaced geometry. This will result in micro-polygons which have a much more uniform size and will most likely provide higher quality images. This is more costly since the displacement shader may be run twice during the dicing process."             parmtag { "parmvop" "1" }             parmtag { "shaderparmcontexts" "" }         }         parm {             name    "vm_sharedisplace"             label   "Share Displacements Between Instances"             type    toggle             default { "off" }             help    "None"             parmtag { "parmvop" "1" }             parmtag { "shaderparmcontexts" "" }         }         parm {             name    "vm_truedisplace"             label   "True Displacements"             type    toggle             default { "on" }             help    "When running displacement shaders, whether the VEX variable P is actually moved (true displacement) or whether bump mapping will be performed."             parmtag { "parmvop" "1" }             parmtag { "shaderparmcontexts" "" }         }     }      group {         name    "oceanshader_2"         label   "Settings"          parm {             name    "sepparm21"             label   "sepparm21"             type    separator             default { "" }         }         parm {             name    "refl_enable"             label   "Enable Reflection"             type    toggle             default { "on" }             parmtag { "parmvop" "1"