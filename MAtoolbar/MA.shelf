opuserdata -n '___Version___' -v '' create_attribadjustfloat1
opuserdata -n '___toolcount___' -v '7' create_attribadjustfloat1
opuserdata -n '___toolid___' -v 'generic_delete' create_attribadjustfloat1
opcf ..

# End of editable subnode
opcf ../..

# Editable subnode
opcf torus/sopnet
opcf create

# Node create_torus2 (Sop/torus)
set reate_torus2 = `run("opadd -e -n -v torus torus2")`
oplocate -x `$arg2 + 4.222072667751867` -y `$arg3 + 5.327064609580745` create_torus2
opset -d off -r off -h off -f off -y off -t off -l off -s off -u off -F on -c on -e on -b off create_torus2
opexprlanguage -s hscript create_torus2
opuserdata -n '___Version___' -v '21.0.512' create_torus2

# Node create_scatter1 (Sop/scatter::2.0)
set reate_scatter1 = `run("opadd -e -n -v scatter::2.0 scatter1")`
oplocate -x `$arg2 + 4.222072667751867` -y `$arg3 + 4.327064609580745` create_scatter1
opparm -V 21.0.512 create_scatter1 npts ( 690 )
opset -d off -r off -h off -f off -y off -t off -l off -s off -u off -F on -c on -e on -b off create_scatter1
