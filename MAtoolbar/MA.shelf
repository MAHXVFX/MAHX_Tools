opcf $arg1

# Node $_obj_geo1_lopnet1_sphere1 (Lop/sphere)
set _obj_geo1_lopnet1_sphere1 = `run("opadd -e -n -v sphere sphere1")`
oplocate -x `$arg2 + 3.4478191788456627` -y `$arg3 + -0.096752999640349557` $_obj_geo1_lopnet1_sphere1
chblockbegin
chadd -t 0 0 $_obj_geo1_lopnet1_sphere1 sample_f1
