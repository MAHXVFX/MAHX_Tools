chkey -t 0 -v 1 -m 0 -a 0 -A 0 -T a  -F @finc $_obj_geo1_lopnet1_cylinder1/sample_f3
chadd -t 0 0 $_obj_geo1_lopnet1_cylinder1 computeextents
chkey -t 0 -v 0 -m 0 -a 0 -A 0 -T a  -F 'if(!strcmp(chs("axis_control"), "none") && !strcmp(chs("height_control"), "none") && !strcmp(chs("radiusBottom_control"), "none")&& !strcmp(chs("radiusTop_control"), "none"), 0, 1)' $_obj_geo1_lopnet1_cylinder1/computeextents
chblockend
opparm -V 1.0 $_obj_geo1_lopnet1_cylinder1 primpath ( /Geometry/tube ) scale ( 0.1 )
opset -d off -r off -h off -f off -y off -t off -l off -s off -u off -F on -c on -e on -b off -D off $_obj_geo1_lopnet1_cylinder1
