  <tool name="OpenHipPath" label="OpenHipPath" icon="hicon:/SVGIcons.index?BUTTONS_addassetdirectory.svg">
    <script scriptType="python"><![CDATA[import hou
import os
import subprocess
# 猫聨路氓聫聳氓陆聯氓聣聧Houdini氓路楼莽篓聥忙聳聡盲禄露莽職聞氓庐聦忙聲麓猫路炉氓戮聞
current_hip_path = hou.hipFile.path()
# 氓娄聜忙聻聹氓聫陋茅聹聙猫娄聛忙聳聡盲禄露氓陇鹿猫路炉氓戮聞猫聙聦盲赂聧氓聦聟氓聬芦忙聳聡盲禄露氓聬聧茂录聦氓聫炉盲禄楼盲陆驴莽聰篓os忙篓隆氓聺聴氓陇聞莽聬聠
current_directory = os.path.dirname(current_hip_path)
#氓掳聠芒聙聹/芒聙聺氓陇聞莽聬聠忙聢聬芒聙聹\芒聙聺茂录聦猫陆卢氓聦聳盲赂潞windows莽鲁禄莽禄聼盲赂颅莽職聞猫路炉氓戮聞
normalized_path = os.path.normpath(current_directory)

folder_path = normalized_path
subprocess.run(['explorer.exe', folder_path], shell=True)]]></script>
  </tool>

  <tool name="Cam images" label="Cam images" icon="hicon:/SVGIcons.index?BUTTONS_add_image.svg">
    <script scriptType="python"><![CDATA[import sys
import toolutils

outputitem = None
inputindex = -1
inputitem = None
outputindex = -1

num_args = 1
h_extra_args = ''
pane = toolutils.activePane(kwargs)
if not isinstance(pane, hou.NetworkEditor):
    pane = hou.ui.paneTabOfType(hou.paneTabType.NetworkEditor)
    if pane is None:
       hou.ui.displayMessage(
               'Cannot create node: cannot find any network pane')
       sys.exit(0)
else: # We're creating this tool from the TAB menu inside a network editor
    pane_node = pane.pwd()
    if "outputnodename" in kwargs and "inputindex" in kwargs:
        outputitem = pane_node.item(kwargs["outputnodename"])
        inputindex = kwargs["inputindex"]
        h_extra_args += 'set arg4 = "' + kwargs["outputnodename"] + '"\n'
        h_extra_args += 'set arg5 = "' + str(inputindex) + '"\n'
        num_args = 6
    if "inputnodename" in kwargs and "outputindex" in kwargs:
        inputitem = pane_node.item(kwargs["inputnodename"])
        outputindex = kwargs["outputindex"]
        h_extra_args += 'set arg6 = "' + kwargs["inputnodename"] + '"\n'
        h_extra_args += 'set arg9 = "' + str(outputindex) + '"\n'
        num_args = 9
    if "autoplace" in kwargs:
        autoplace = kwargs["autoplace"]
    else:
        autoplace = False
    # If shift-clicked we want to auto append to the current
    # node
    if "shiftclick" in kwargs and kwargs["shiftclick"]:
        if inputitem is None:
            inputitem = pane.currentNode()
            outputindex = 0
    if "nodepositionx" in kwargs and             "nodepositiony" in kwargs:
        try:
            pos = [ float( kwargs["nodepositionx"] ),
                    float( kwargs["nodepositiony"] )]
        except:
            pos = None
    else:
        pos = None

    if not autoplace and not pane.listMode():
        if pos is not None:
            pass
        elif outputitem is None:
            pos = pane.selectPosition(inputitem, outputindex, None, -1)
        else:
            pos = pane.selectPosition(inputitem, outputindex,
                                      outputitem, inputindex)

    if pos is not None:
        if "node_bbox" in kwargs:
            size = kwargs["node_bbox"]
            pos[0] -= size[0] / 2
            pos[1] -= size[1] / 2
        else:
            pos[0] -= 0.573625
            pos[1] -= 0.220625
        h_extra_args += 'set arg2 = "' + str(pos[0]) + '"\n'
        h_extra_args += 'set arg3 = "' + str(pos[1]) + '"\n'
h_extra_args += 'set argc = "' + str(num_args) + '"\n'

pane_node = pane.pwd()
child_type = pane_node.childTypeCategory().nodeTypes()

if 'pythonscript' not in child_type:
   hou.ui.displayMessage(
           'Cannot create node: incompatible pane network type')
   sys.exit(0)

# First clear the node selection
pane_node.setSelected(False, True)

h_path = pane_node.path()
h_preamble = 'set arg1 = "' + h_path + '"\n'
h_cmd = r'''
if ($argc < 2 || "$arg2" == "") then
   set arg2 = 0
endif
if ($argc < 3 || "$arg3" == "") then
   set arg3 = 0
endif
# Automatically generated script
# $arg1 - the path to add this node
# $arg2 - x position of the tile
# $arg3 - y position of the tile
# $arg4 - input node to wire to
# $arg5 - which input to wire to
# $arg6 - output node to wire to
# $arg7 - the type of this node
# $arg8 - the node is an indirect input
# $arg9 - index of output from $arg6

\set noalias = 1
set saved_path = `execute("oppwf")`
opcf $arg1

# Node $_obj_topnet1_File (Top/filepattern)
set _obj_topnet1_File = `run("opadd -e -n -v filepattern File")`
oplocate -x `$arg2 + 0` -y `$arg3 + 0` $_obj_topnet1_File
opparm -V 4 $_obj_topnet1_File folder0 ( 1 ) pattern ( '$HIP/../../cmp/xiaoyang/001/*.mov' ) folder1 ( 1 ) split ( off ) folder2 ( 1 ) overrideresultdatatag ( on ) resultdatatag ( file/video )
opcolor -c 0.80000001192092896 0.016000000759959221 0.016000000759959221 $_obj_topnet1_File
opset -d off -r off -h off -f off -y off -t off -l off -s off -u off -F off -c off -e on -b off $_obj_topnet1_File
opexprlanguage -s hscript $_obj_topnet1_File
opuserdata -n '___Version___' -v '4' $_obj_topnet1_File
opset -p on $_obj_topnet1_File
opcf $arg1

# Node $_obj_topnet1_waitforall3 (Top/waitforall)
set _obj_topnet1_waitforall3 = `run("opadd -e -n -v waitforall waitforall3")`
oplocate -x `$arg2 + 0` -y `$arg3 + -8.8089603500353455` $_obj_topnet1_waitforall3
opparm $_obj_topnet1_waitforall3  pdg_partitionmergeattributes ( 1 )
opset -d off -r off -h off -f off -y off -t off -l off -s off -u off -F on -c off -e on -b off $_obj_topnet1_waitforall3
opexprlanguage -s hscript $_obj_topnet1_waitforall3
opuserdata -n '___Version___' -v '1' $_obj_topnet1_waitforall3
opset -p on $_obj_topnet1_waitforall3
opcf $arg1

# Node $_obj_topnet1_waitforall1 (Top/waitforall)
set _obj_topnet1_waitforall1 = `run("opadd -e -n -v waitforall waitforall1")`
oplocate -x `$arg2 + 0` -y `$arg3 + -5.2642309716015578` $_obj_topnet1_waitforall1
opparm $_obj_topnet1_waitforall1  pdg_partitionmergeattributes ( 1 )
opparm -V 1 $_obj_topnet1_waitforall1 attributes ( 1 1 ) pdg_partitionignorefailures ( on )
opset -d off -r off -h off -f off -y off -t off -l off -s off -u off -F on -c off -e on -b off $_obj_topnet1_waitforall1
opexprlanguage -s hscript $_obj_topnet1_waitforall1
opuserdata -n '___Version___' -v '1' $_obj_topnet1_waitforall1
opset -p on $_obj_topnet1_waitforall1
opcf $arg1

# Node $_obj_topnet1_Background_application (Top/pythonscript)
set _obj_topnet1_Background_application = `run("opadd -e -n -v pythonscript Background_application")`
oplocate -x `$arg2 + 0` -y `$arg3 + -11.282412928655557` $_obj_topnet1_Background_application
opparm $_obj_topnet1_Background_application  expectedoutputfiles ( 0 )
opparm -V 4 $_obj_topnet1_Background_application evaluation ( 1 ) script ( '# 氓掳聠猫聝聦忙聶炉氓聸戮氓潞聰莽聰篓莽禄聶忙聣聙忙聹聣莽聸赂忙聹潞\nimport hou\ndef get_cameras_in_obj():\n    cameras = []\n    for node in hou.node("/").allSubChildren():\n        if node.type().name()=="cam":\n            cameras.append(node)\n    return cameras\nF_name=work_item.attribValue("F_name")\ncameras = get_cameras_in_obj()   \nfor camera in cameras:\n    camera.parm("vm_background").set(f"$HIP/images/{F_name}/cam.$F.jpg")\n    camera.parm("vm_bgenable").set(0)\n' )
opcolor -c 0.45100000500679016 0.36899998784065247 0.79600000381469727 $_obj_topnet1_Background_application
opset -d on -r off -h off -f off -y off -t off -l off -s off -u off -F off -c off -e on -b off $_obj_topnet1_Background_application
opexprlanguage -s hscript $_obj_topnet1_Background_application
opuserdata -n '___Version___' -v '4' $_obj_topnet1_Background_application
opuserdata -n '___toolcount___' -v '1' $_obj_topnet1_Background_application
opuserdata -n '___toolid___' -v 'object_cop2plane' $_obj_topnet1_Background_application
opset -p on $_obj_topnet1_Background_application
opcf $arg1

# Node $_obj_topnet1_pythonscript (Top/pythonscript)
set _obj_topnet1_pythonscript = `run("opadd -e -n -v pythonscript pythonscript")`
oplocate -x `$arg2 + 0` -y `$arg3 + -2.8416128120039876` $_obj_topnet1_pythonscript
opparm $_obj_topnet1_pythonscript  expectedoutputfiles ( 0 )
opparm -V 4 $_obj_topnet1_pythonscript evaluation ( 1 ) script ( 'import os\nFile_output = work_item.expectedInputFiles[0][0]\nfilename = os.path.basename(File_output)\nname_without_extension = os.path.splitext(filename)[0]\nwork_item.setStringAttrib("F_name",f"{name_without_extension}")\n' )
opset -d off -r off -h off -f off -y off -t off -l off -s off -u off -F on -c off -e on -b off $_obj_topnet1_pythonscript
opexprlanguage -s hscript $_obj_topnet1_pythonscript
opuserdata -n '___Version___' -v '4' $_obj_topnet1_pythonscript
opuserdata -n '___toolcount___' -v '1' $_obj_topnet1_pythonscript
opuserdata -n '___toolid___' -v 'object_cop2plane' $_obj_topnet1_pythonscript
opset -p on $_obj_topnet1_pythonscript
opcf $arg1

# Node $_obj_topnet1_Notice (Top/pythonscript)
set _obj_topnet1_Notice = `run("opadd -e -n -v pythonscript Notice")`
oplocate -x `$arg2 + 0` -y `$arg3 + -9.9417776456482141` $_obj_topnet1_Notice
opparm $_obj_topnet1_Notice  expectedoutputfiles ( 0 )
opparm -V 4 $_obj_topnet1_Notice evaluation ( 1 ) script ( 'end=1000+work_item.attribValue("partitionsize")\nprint(f"氓赂搂猫聦聝氓聸麓茂录職1001-{end}")\n' )
opset -d off -r off -h off -f off -y off -t off -l off -s off -u off -F on -c off -e on -b off $_obj_topnet1_Notice
opexprlanguage -s hscript $_obj_topnet1_Notice
opuserdata -n '___Version___' -v '4' $_obj_topnet1_Notice
opuserdata -n '___toolcount___' -v '1' $_obj_topnet1_Notice
opuserdata -n '___toolid___' -v 'object_cop2plane' $_obj_topnet1_Notice
opset -p on $_obj_topnet1_Notice
opcf $arg1

# Node $_obj_topnet1_ffmpegextractimages (Top/ffmpegextractimages)
set _obj_topnet1_ffmpegextractimages = `run("opadd -e -n -v ffmpegextractimages ffmpegextractimages")`
oplocate -x `$arg2 + 0` -y `$arg3 + -4.1438309827118633` $_obj_topnet1_ffmpegextractimages
chblockbegin
chadd -t 41.666666666666664 41.666666666666664 $_obj_topnet1_ffmpegextractimages fps
chkey -t 41.666666666666664 -v 25 -m 0 -a 0 -A 0 -T a  -F '$FPS' $_obj_topnet1_ffmpegextractimages/fps
chblockend
opparm -V 1 $_obj_topnet1_ffmpegextractimages pdg_workitemgeneration ( 3 ) fps ( fps ) outputfilepattern ( '$HIP/images/`@F_name`/camold%04d.jpg' ) folder3 ( 1 ) ffmpegbinary ( 2 ) customffmpegbinary ( C:/CgTeamWork_v7/bin/base/app/ffmpeg.exe ) enablecustomcommand ( on ) ffmpegcommand ( '"`chs("customffmpegbinary")`" -i "`pdginput(0, file/video, 0)`" -vf fps=`$FPS` -q:v 1 "`chs("outputfilepattern")`"' )
opset -d off -r off -h off -f off -y off -t off -l off -s off -u off -F on -c off -e on -b off $_obj_topnet1_ffmpegextractimages
opexprlanguage -s hscript $_obj_topnet1_ffmpegextractimages
opuserdata -n '___Version___' -v '1' $_obj_topnet1_ffmpegextractimages
opset -p on $_obj_topnet1_ffmpegextractimages
opcf $arg1

# Node $_obj_topnet1_filepattern2 (Top/filepattern)
set _obj_topnet1_filepattern2 = `run("opadd -e -n -v filepattern filepattern2")`
oplocate -x `$arg2 + 0` -y `$arg3 + -6.3846309604912523` $_obj_topnet1_filepattern2
opparm -V 4 $_obj_topnet1_filepattern2 folder0 ( 1 ) pdg_workitemgeneration ( 3 ) pattern ( '$HIP/images/`@F_name`/camold*' ) folder1 ( 1 ) includeextensions ( on ) folder2 ( 1 )
opset -d off -r off -h off -f off -y off -t off -l off -s off -u off -F on -c off -e on -b off $_obj_topnet1_filepattern2
opexprlanguage -s hscript $_obj_topnet1_filepattern2
opuserdata -n '___Version___' -v '4' $_obj_topnet1_filepattern2
opset -p on $_obj_topnet1_filepattern2
opcf $arg1

# Node $_obj_topnet1_waitforall (Top/waitforall)
set _obj_topnet1_waitforall = `run("opadd -e -n -v waitforall waitforall")`
oplocate -x `$arg2 + 0` -y `$arg3 + -1.5393946412961115` $_obj_topnet1_waitforall
opparm $_obj_topnet1_waitforall  pdg_partitionmergeattributes ( 1 )
opparm -V 1 $_obj_topnet1_waitforall attributes ( 1 1 ) pdg_partitionignorefailures ( on )
opset -d off -r off -h off -f off -y off -t off -l off -s off -u off -F on -c off -e on -b off $_obj_topnet1_waitforall
opexprlanguage -s hscript $_obj_topnet1_waitforall
opuserdata -n '___Version___' -v '1' $_obj_topnet1_waitforall
opset -p on $_obj_topnet1_waitforall
opcf $arg1

# Node $_obj_topnet1_pythonscript1 (Top/pythonscript)
set _obj_topnet1_pythonscript1 = `run("opadd -e -n -v pythonscript pythonscript1")`
oplocate -x `$arg2 + 0` -y `$arg3 + -7.5050309493809451` $_obj_topnet1_pythonscript1
opparm $_obj_topnet1_pythonscript1  expectedoutputfiles ( 0 )
opparm -V 4 $_obj_topnet1_pythonscript1 evaluation ( 1 ) script ( '# Script code that runs for each task in the node.\n#\n# The following variables are available:\n# work_item    - the work item currently running \n# graph        - the graph attributes for the current work item\n#\n# In addition to the above, in-process scripts can also access:\n# self         - the current PDG node\n# parent_item  - the parent work item, if it exists\nimport os\nfrom pathlib import Path\ndef rename_file(old_path,new_path):\n    if not os.path.exists(old_path):\n        #print("忙聳聡盲禄露盲赂聧氓颅聵氓聹篓")\n        return False\n    # if os.path.exists(new_path):\n    #     #print("猫聝聦忙聶炉氓聸戮氓路虏莽禄聫氓颅聵氓聹篓")\n    #     return False\n    #os.rename(old_path,new_path)   #new_path猫聥楼氓颅聵氓聹篓氓掳卤忙聤楼茅聰聶\n    os.replace(old_path,new_path) #new_path猫聥楼氓颅聵氓聹篓氓掳卤猫娄聠莽聸聳\n    return True\n#    \nid=work_item.index\nid+=1001\nOut=work_item.attribValue("directory")\nfilename=work_item.attribValue("filename")\nold_path=f"{Out}"+"/"+f"{filename}"\npath_obj=Path(old_path)\nfilename=path_obj.stem\nextension=path_obj.suffix\nprefix="cam"\nnew_filename=f"{prefix}.{id}{extension}"\nnew_path=path_obj.with_name(new_filename)\nrename_file(old_path,new_path)\n#print(new_path)' )
opset -d off -r off -h off -f off -y off -t off -l off -s off -u off -F on -c off -e on -b off $_obj_topnet1_pythonscript1
opexprlanguage -s hscript $_obj_topnet1_pythonscript1
opuserdata -n '___Version___' -v '4' $_obj_topnet1_pythonscript1
opuserdata -n '___toolcount___' -v '1' $_obj_topnet1_pythonscript1
opuserdata -n '___toolid___' -v 'object_cop2plane' $_obj_topnet1_pythonscript1
opset -p on $_obj_topnet1_pythonscript1

opcf $arg1
opcf $arg1
opwire -n $_obj_topnet1_pythonscript1 -0 $_obj_topnet1_waitforall3
opcf $arg1
opwire -n $_obj_topnet1_ffmpegextractimages -0 $_obj_topnet1_waitforall1
opcf $arg1
opwire -n $_obj_topnet1_Notice -0 $_obj_topnet1_Background_application
opcf $arg1
opwire -n $_obj_topnet1_waitforall -0 $_obj_topnet1_pythonscript
opcf $arg1
opwire -n $_obj_topnet1_waitforall3 -0 $_obj_topnet1_Notice
opcf $arg1
opwire -n $_obj_topnet1_pythonscript -0 $_obj_topnet1_ffmpegextractimages
opcf $arg1
opwire -n $_obj_topnet1_waitforall1 -0 $_obj_topnet1_filepattern2
opcf $arg1
opwire -n $_obj_topnet1_File -0 $_obj_topnet1_waitforall
opcf $arg1
opwire -n $_obj_topnet1_filepattern2 -0 $_obj_topnet1_pythonscript1

set oidx = 0
if ($argc >= 9 && "$arg9" != "") then
    set oidx = $arg9
endif

if ($argc >= 5 && "$arg4" != "") then
    set output = $_obj_topnet1_Background_application
    opwire -n $output -$arg5 $arg4
endif
if ($argc >= 6 && "$arg6" != "") then
    set input = $_obj_topnet1_File
    if ($arg8) then
        opwire -n -i $arg6 -0 $input
    else
        opwire -n -o $oidx $arg6 -0 $input
    endif
endif
opcf $saved_path
'''
hou.hscript(h_preamble + h_extra_args + h_cmd)
#-------------忙路禄氓聤聽NetworkBox-------------#
import random
text="氓掳聠mov猫陆卢忙聧垄盲赂潞jpg氓潞聫氓聢聴氓聸戮"  #NetworkBox忙聽聡茅垄聵
nodes = hou.selectedNodes()
scene = nodes[0].parent()
network_box = scene.createNetworkBox()
mycolor = hou.Color()
hue = random.uniform(0, 360)  # 猫聣虏莽聸赂
saturation = random.uniform(0, 1)  # 茅楼卤氓聮聦氓潞娄
value = random.uniform(0.5, 1)       # 盲潞庐氓潞娄
mycolor.setHSV((hue,saturation,value)) # 莽聰篓HSV猫庐戮氓庐職茅垄聹猫聣虏
for node in nodes:
    network_box.addItem(node)
network_box.fitAroundContents() # 猫聡陋氓聤篓猫掳聝忙聲麓氓陇搂氓掳聫氓聢掳忙聹聙莽麓搂氓聡聭莽聤露忙聙聛
#box_pos = network_box.position()  # 猫驴聰氓聸聻 (x, y) 氓聺聬忙聽聡
box_size = network_box.size()     # 猫驴聰氓聸聻 (width, height)
network_box.setSize([box_size[0]+2,box_size[1]])
network_box.setColor(mycolor)
network_box.setComment(text)]]></script>
  </tool>

  <tool name="Example Instancer " label="" icon="hicon:/SVGIcons.index?BUTTONS_light_solo.svg">
    <script scriptType="python"><![CDATA[
import sys
import toolutils

outputitem = None
inputindex = -1
inputitem = None
outputindex = -1

num_args = 1
h_extra_args = ''
pane = toolutils.activePane(kwargs)
if not isinstance(pane, hou.NetworkEditor):
    pane = hou.ui.paneTabOfType(hou.paneTabType.NetworkEditor)
    if pane is None:
       hou.ui.displayMessage(
               'Cannot create node: cannot find any network pane')
       sys.exit(0)
else: # We're creating this tool from the TAB menu inside a network editor
    pane_node = pane.pwd()
    if "outputnodename" in kwargs and "inputindex" in kwargs:
        outputitem = pane_node.item(kwargs["outputnodename"])
        inputindex = kwargs["inputindex"]
        h_extra_args += 'set arg4 = "' + kwargs["outputnodename"] + '"\n'
        h_extra_args += 'set arg5 = "' + str(inputindex) + '"\n'
        num_args = 6
    if "inputnodename" in kwargs and "outputindex" in kwargs:
        inputitem = pane_node.item(kwargs["inputnodename"])
        outputindex = kwargs["outputindex"]
        h_extra_args += 'set arg6 = "' + kwargs["inputnodename"] + '"\n'
        h_extra_args += 'set arg9 = "' + str(outputindex) + '"\n'
        num_args = 9
    if "autoplace" in kwargs:
        autoplace = kwargs["autoplace"]
    else:
        autoplace = False
    # If shift-clicked we want to auto append to the current
    # node
    if "shiftclick" in kwargs and kwargs["shiftclick"]:
        if inputitem is None:
            inputitem = pane.currentNode()
            outputindex = 0
    if "nodepositionx" in kwargs and             "nodepositiony" in kwargs:
        try:
            pos = [ float( kwargs["nodepositionx"] ),
                    float( kwargs["nodepositiony"] )]
        except:
            pos = None
    else:
        pos = None

    if not autoplace and not pane.listMode():
        if pos is not None:
            pass
        elif outputitem is None:
            pos = pane.selectPosition(inputitem, outputindex, None, -1)
        else:
            pos = pane.selectPosition(inputitem, outputindex,
                                      outputitem, inputindex)

    if pos is not None:
        if "node_bbox" in kwargs:
            size = kwargs["node_bbox"]
            pos[0] -= size[0] / 2
            pos[1] -= size[1] / 2
        else:
            pos[0] -= 0.573625
            pos[1] -= 0.220625
        h_extra_args += 'set arg2 = "' + str(pos[0]) + '"\n'
        h_extra_args += 'set arg3 = "' + str(pos[1]) + '"\n'
h_extra_args += 'set argc = "' + str(num_args) + '"\n'

pane_node = pane.pwd()
child_type = pane_node.childTypeCategory().nodeTypes()

if 'sopcreate' not in child_type:
   hou.ui.displayMessage(
           'Cannot create node: incompatible pane network type')
   sys.exit(0)

# First clear the node selection
pane_node.setSelected(False, True)

h_path = pane_node.path()
h_preamble = 'set arg1 = "' + h_path + '"\n'
h_cmd = r'''
if ($argc < 2 || "$arg2" == "") then
   set arg2 = 0
