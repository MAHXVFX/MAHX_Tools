oplocate -x `$arg2 + 0.10798167510406742` -y `$arg3 + -1.9721657037907878` $_obj_geo1_lopnet1_instancer1
opparm -V 21.0.512 $_obj_geo1_lopnet1_instancer1 primpath ( /Geometry/shapes ) locgroup ( 1 ) transformsourcemode ( points ) locationpattern ( %type:Boundable ) protogroup ( 1 ) protopattern ( %type:Boundable ) protooptionsgroup ( 1 ) seed ( 2.74 )
opset -d on -r off -h off -f off -y off -t off -l off -s off -u off -F on -c on -e on -b off -D off $_obj_geo1_lopnet1_instancer1
opexprlanguage -s hscript $_obj_geo1_lopnet1_instancer1
