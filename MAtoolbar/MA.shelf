# Node create_attribrandomize1 (Sop/attribrandomize)
set reate_attribrandomize1 = `run("opadd -e -n -v attribrandomize attribrandomize1")`
oplocate -x `$arg2 + 4.222072667751867` -y `$arg3 + 2.2889488388489765` create_attribrandomize1
opparm create_attribrandomize1  ramp ( 3 ) values ( 4 )
opparm create_attribrandomize1 name ( N ) folder0 ( 1 1 ) distribution ( uniformorient ) coneangle ( 180 ) seed ( 1.6 ) ramp2pos ( 0.5 ) ramp2value ( 0.5 ) ramp3pos ( 1 ) ramp3value ( 1 )
opset -d on -r on -h off -f off -y off -t off -l off -s off -u off -F on -c on -e on -b off create_attribrandomize1
opexprlanguage -s hscript create_attribrandomize1
opuserdata -n '___Version___' -v '' create_attribrandomize1
oporder -e torus2 scatter1 attribadjustfloat1 attribrandomize1 
opcf ..

# End of editable subnode
opcf ../..

opset -p on $_obj_geo1_lopnet1_torus

opcf $arg1
opwire -n $_obj_geo1_lopnet1_torus -0 $_obj_geo1_lopnet1_instancer1
opwire -n $_obj_geo1_lopnet1_cone1 -1 $_obj_geo1_lopnet1_instancer1
opcf $arg1
opwire -n $_obj_geo1_lopnet1_cylinder1 -0 $_obj_geo1_lopnet1_sphere1
opcf $arg1
opwire -n $_obj_geo1_lopnet1_sphere1 -0 $_obj_geo1_lopnet1_cone1
opcf $arg1
opcf $arg1

set oidx = 0
if ($argc >= 9 && "$arg9" != "") then
    set oidx = $arg9
endif

if ($argc >= 5 && "$arg4" != "") then
    set output = $_obj_geo1_lopnet1_instancer1
    opwire -n $output -$arg5 $arg4
endif
if ($argc >= 6 && "$arg6" != "") then
    set input = $_obj_geo1_lopnet1_torus
    if ($arg8) then
        opwire -n -i $arg6 -0 $input
    else
        opwire -n -o $oidx $arg6 -0 $input
    endif
endif
opcf $saved_path
'''
hou.hscript(h_preamble + h_extra_args + h_cmd)
]]></script>
