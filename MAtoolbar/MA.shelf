opuserdata -n '___Version___' -v '2' $_obj_geo1_lopnet1_torus

# Editable subnode
opcf torus/sopnet

# Node create (Sop/subnet)
set reate = `run("opadd -e -n -v subnet create")`
oplocate -x `$arg2 + 1.71309` -y `$arg3 + 4.7211299999999996` create
opset -d off -r off -h off -f off -y off -t off -l off -s off -u off -F on -c on -e on -b off create
opexprlanguage -s hscript create
opuserdata -n '___Version___' -v '21.0.512' create
opcf create

# Node create_attribadjustfloat1 (Sop/attribadjustfloat)
set reate_attribadjustfloat1 = `run("opadd -e -n -v attribadjustfloat attribadjustfloat1")`
oplocate -x `$arg2 + 4.222072667751867` -y `$arg3 + 3.5095260897161449` create_attribadjustfloat1
opparm create_attribadjustfloat1  remapramp ( 2 ) nvalues ( 1 )
opparm create_attribadjustfloat1 valuetype ( noise ) singlevalue ( 0.5 ) outlierseed ( 90 ) randomseed ( 63 ) folder9 ( 1 ) animated ( on ) remapramp2pos ( 1 ) remapramp2value ( 1 )
opset -d off -r off -h off -f off -y off -t off -l off -s off -u off -F on -c on -e on -b off create_attribadjustfloat1
