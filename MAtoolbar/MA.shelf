  <tool name="selected name" label="" icon="C:/Users/mahx_/Pictures/AI/mahx_selected name_custom.png">
    <script scriptType="python"><![CDATA[import hou
from PySide6 import QtWidgets, QtCore, QtGui

def create_attribute_split_tool():
    # 忙拢聙忙聼楼忙聵炉氓聬娄茅聙聣盲赂颅猫聤聜莽聜鹿
    selected_nodes = hou.selectedNodes()
    if not selected_nodes:
        hou.ui.displayMessage("猫炉路氓聟聢茅聙聣忙聥漏盲赂聙盲赂陋猫聤聜莽聜鹿茂录聛", severity=hou.severityType.Error)
        return
    
    node = selected_nodes[0] #茅聙聣盲赂颅莽職聞莽卢卢盲赂聙盲赂陋猫聤聜莽聜鹿
    
    # 忙拢聙忙聼楼忙聵炉氓聬娄盲赂潞氓聡聽盲陆聲猫聤聜莽聜鹿
    if node.type().category().name() != "Sop":
        hou.ui.displayMessage("猫炉路茅聙聣忙聥漏氓聡聽盲陆聲猫聤聜莽聜鹿茂录聛", severity=hou.severityType.Error)
        return
    
    # 猫聨路氓聫聳氓聡聽盲陆聲盲陆聯
    geo = node.geometry()
    if not geo:
        hou.ui.displayMessage("猫聤聜莽聜鹿忙虏隆忙聹聣氓聡聽盲陆聲盲陆聯茂录聛", severity=hou.severityType.Error)
        return
    
    # 猫聡陋氓聤篓忙拢聙忙聼楼氓卤聜莽潞搂氓卤聻忙聙搂氓聫炉莽聰篓忙聙搂
    def has_valid_attributes(level):
        try:
            if level == "Point":
                return any(attr.dataType().name() in ["Int", "String"] for attr in geo.pointAttribs())
            elif level == "Primitive":
                return any(attr.dataType().name() in ["Int", "String"] for attr in geo.primAttribs())
            return False
        except:
            return False
    
    # 猫聡陋氓聤篓茅聙聣忙聥漏氓聫炉莽聰篓莽職聞氓卤聜莽潞搂
    current_level = "Primitive"
    if not has_valid_attributes(current_level):
        # 氓掳聺猫炉聲氓聢聡忙聧垄氓聢掳Point氓卤聜莽潞搂
        current_level = "Point"
        if not has_valid_attributes(current_level):
            hou.ui.displayMessage("猫聤聜莽聜鹿忙虏隆忙聹聣莽卢娄氓聬聢忙聺隆盲禄露莽職聞忙聲麓忙聲掳忙聢聳氓颅聴莽卢娄盲赂虏氓卤聻忙聙搂茂录聛", severity=hou.severityType.Error)
            return
    
    # 氓聢聸氓禄潞氓炉鹿猫炉聺忙隆聠
    dialog = QtWidgets.QDialog(hou.qt.mainWindow())
    dialog.setWindowTitle("Houdini 氓卤聻忙聙搂氓聢聠莽娄禄氓路楼氓聟路")
    dialog.setMinimumSize(400, 200)
    
    # 氓聢聸氓禄潞氓赂聝氓卤聙
    layout = QtWidgets.QVBoxLayout(dialog)
    
    # 忙路禄氓聤聽猫聤聜莽聜鹿盲驴隆忙聛炉
    node_info = QtWidgets.QLabel(f"氓陆聯氓聣聧猫聤聜莽聜鹿: {node.name()}")
    layout.addWidget(node_info)
    
    # 忙路禄氓聤聽氓卤聻忙聙搂氓卤聜莽潞搂茅聙聣忙聥漏
    level_label = QtWidgets.QLabel("猫炉路茅聙聣忙聥漏氓卤聻忙聙搂氓卤聜莽潞搂:")
    layout.addWidget(level_label)
    
    level_combo = QtWidgets.QComboBox()
    level_combo.addItems(["Point", "Primitive"])
    
    # 猫庐戮莽陆庐氓陆聯氓聣聧氓卤聜莽潞搂茂录聢氓聼潞盲潞聨猫聡陋氓聤篓忙拢聙忙碌聥茂录聣
    if current_level == "Point":
        level_combo.setCurrentIndex(0)
    else:
        level_combo.setCurrentIndex(1)
    
    layout.addWidget(level_combo)
    
    # 忙路禄氓聤聽氓卤聻忙聙搂氓聬聧茅聙聣忙聥漏
    attr_label = QtWidgets.QLabel("猫炉路茅聙聣忙聥漏氓卤聻忙聙搂氓聬聧:")
    layout.addWidget(attr_label)
    
    attr_combo = QtWidgets.QComboBox()
    layout.addWidget(attr_combo)
    
    # 氓聡陆忙聲掳茂录職忙聸麓忙聳掳氓卤聻忙聙搂氓聢聴猫隆篓茂录聢氓聫陋氓聦聟氓聬芦忙聲麓忙聲掳氓聮聦氓颅聴莽卢娄盲赂虏莽卤禄氓聻聥茂录聣
    def update_attributes():
        level = level_combo.currentText()
        attr_combo.clear()
        
        try:
            attributes = []
            
            if level == "Point":
                # 猫聨路氓聫聳莽聜鹿氓卤聻忙聙搂
                point_attribs = geo.pointAttribs()
                for attr in point_attribs:
                    # 氓聫陋盲驴聺莽聲聶忙聲麓忙聲掳氓聮聦氓颅聴莽卢娄盲赂虏莽卤禄氓聻聥氓卤聻忙聙搂
                    if attr.dataType().name() in ["Int", "String"]:
                        attributes.append(attr.name())
            
            elif level == "Primitive":
                # 猫聨路氓聫聳氓聸戮氓聟聝氓卤聻忙聙搂
                prim_attribs = geo.primAttribs()
                for attr in prim_attribs:
                    # 氓聫陋盲驴聺莽聲聶忙聲麓忙聲掳氓聮聦氓颅聴莽卢娄盲赂虏莽卤禄氓聻聥氓卤聻忙聙搂
                    if attr.dataType().name() in ["Int", "String"]:
                        attributes.append(attr.name())
            
            # 忙聦聣氓颅聴忙炉聧茅隆潞氓潞聫忙聨聮氓潞聫
            attributes.sort()
            attr_combo.addItems(attributes)
            
            # 氓娄聜忙聻聹忙虏隆忙聹聣氓卤聻忙聙搂茂录聦氓掳聺猫炉聲猫聡陋氓聤篓氓聢聡忙聧垄氓卤聜莽潞搂
            if not attributes:
                new_level = "Point" if level == "Primitive" else "Primitive"
                if new_level == "Point":
                    level_combo.setCurrentIndex(0)
                else:
                    level_combo.setCurrentIndex(1)
                
                # 茅聙聮氓陆聮猫掳聝莽聰篓忙聸麓忙聳掳氓卤聻忙聙搂
                update_attributes()
                
        except Exception as e:
            # 忙聣聯氓聧掳茅聰聶猫炉炉盲驴隆忙聛炉茂录聦盲陆聠盲赂聧盲赂颅忙聳颅忙聣搂猫隆聦
            print(f"猫聨路氓聫聳氓卤聻忙聙搂忙聴露氓聡潞茅聰聶: {str(e)}")
    
    # 氓聢聺氓搂聥忙聸麓忙聳掳氓聮聦猫驴聻忙聨楼盲驴隆氓聫路
    update_attributes()
    level_combo.currentTextChanged.connect(update_attributes)
    
    # 忙路禄氓聤聽忙聦聣茅聮庐
    button_box = QtWidgets.QDialogButtonBox(
        QtWidgets.QDialogButtonBox.Ok | QtWidgets.QDialogButtonBox.Cancel
    )
    button_box.accepted.connect(dialog.accept)
    button_box.rejected.connect(dialog.reject)
    layout.addWidget(button_box)
    
    # 忙聵戮莽陇潞氓炉鹿猫炉聺忙隆聠
    if dialog.exec_():
        level = level_combo.currentText()
        attribute = attr_combo.currentText()
        
        # 氓娄聜忙聻聹氓卤聻忙聙搂氓聬聧盲赂潞莽漏潞茂录聦猫炉麓忙聵聨忙虏隆忙聹聣莽卢娄氓聬聢忙聺隆盲禄露莽職聞氓卤聻忙聙搂
        if not attribute:
            hou.ui.displayMessage("忙虏隆忙聹聣忙聣戮氓聢掳莽卢娄氓聬聢忙聺隆盲禄露莽職聞氓卤聻忙聙搂茂录聛", severity=hou.severityType.Warning)
            return
        
        # 忙聰露茅聸聠氓卤聻忙聙搂氓聙录
        unique_values = set()
        
        try:
            if level == "Point":
                # 莽隆庐盲驴聺氓卤聻忙聙搂氓颅聵氓聹篓
                if geo.findPointAttrib(attribute):
                    for point in geo.points():
                        try:
                            value = point.attribValue(attribute)
                            unique_values.add(value)
                        except:
                            print(f"忙聴聽忙鲁聲猫聨路氓聫聳莽聜鹿 {point.number()} 莽職聞氓卤聻忙聙搂 '{attribute}' 氓聙录")
            
            elif level == "Primitive":
                # 莽隆庐盲驴聺氓卤聻忙聙搂氓颅聵氓聹篓
                if geo.findPrimAttrib(attribute):
                    for prim in geo.prims():
                        try:
                            value = prim.attribValue(attribute)
                            unique_values.add(value)
                        except:
                            print(f"忙聴聽忙鲁聲猫聨路氓聫聳氓聸戮氓聟聝 {prim.number()} 莽職聞氓卤聻忙聙搂 '{attribute}' 氓聙录")            
        
        except Exception as e:
            hou.ui.displayMessage(f"猫聨路氓聫聳氓卤聻忙聙搂氓聙录氓陇卤猫麓楼: {str(e)}", severity=hou.severityType.Warning)
            return
        
        # 氓娄聜忙聻聹忙虏隆忙聹聣忙聣戮氓聢掳盲禄禄盲陆聲氓卤聻忙聙搂氓聙录
        if not unique_values:
            hou.ui.displayMessage("忙虏隆忙聹聣忙聣戮氓聢掳盲禄禄盲陆聲氓卤聻忙聙搂氓聙录茂录聛", severity=hou.severityType.Warning)
            return
        
        # 猫聨路氓聫聳氓聨聼氓搂聥猫聤聜莽聜鹿盲陆聧莽陆庐盲陆聹盲赂潞氓赂聝氓卤聙氓聼潞氓聡聠
        base_position = node.position()
        
        # 猫庐隆莽庐聴忙聳掳猫聤聜莽聜鹿盲陆聧莽陆庐茂录職氓聬聭盲赂聥氓聛聫莽搂禄2盲赂陋氓聧聲盲陆聧
        new_position = [
            base_position[0],  # X氓聺聬忙聽聡盲赂聧氓聫聵
            base_position[1] - 2  # Y氓聺聬忙聽聡氓聬聭盲赂聥莽搂禄氓聤篓2盲赂陋氓聧聲盲陆聧
        ]
        
        # 氓聢聸氓禄潞忙聮陇茅聰聙莽禄聞
        with hou.undos.group("氓卤聻忙聙搂氓聢聠莽娄禄氓路楼氓聟路忙聯聧盲陆聹"):
            # 氓聢聸氓禄潞盲赂聙盲赂陋氓聦聟
            mycolor = hou.Vector3(0.451,0.369,0.796)
            parent_node = node.parent()
            subnet = parent_node.createNode("subnet","Cryptomatte")
            subnet.setPosition([node.position()[0],node.position()[1]-1])
            subnet.setColor(hou.Color(mycolor))
            subnet.setFirstInput(node)
            subnet_0= subnet.indirectInputs()[0] # 猫聨路氓聫聳氓聦聟茅聡聦茅聺垄莽職聞莽卢卢盲赂聙盲赂陋忙聨楼氓聫拢莽職聞猫聤聜莽聜鹿
            # 氓聢聸氓禄潞 blast 猫聤聜莽聜鹿
            for i, value in enumerate(unique_values):
                # 氓聢聸氓禄潞 blast 猫聤聜莽聜鹿
                blast = subnet.createNode("blast", f"blast_{attribute}_{i}")
                
                # 猫庐戮莽陆庐猫聤聜莽聜鹿茅垄聹猫聣虏盲赂潞莽潞炉茅禄聭猫聣虏
                blast.setColor(hou.Color(0, 0, 0))
                
                # 猫驴聻忙聨楼氓聢掳氓聦聟茅聡聦茅聺垄莽職聞莽卢卢盲赂聙盲赂陋忙聨楼氓聫拢莽職聞猫聤聜莽聜鹿
                blast.setInput(0, subnet_0)
                
                # 猫庐戮莽陆庐盲陆聧莽陆庐 - 忙篓陋氓聬聭忙聨聮氓聢聴
                blast.setPosition([
                    new_position[0] + i * 2,  # 忙篓陋氓聬聭茅聴麓茅職聰2盲赂陋氓聧聲盲陆聧
                    new_position[1] - i * 0.4 
                ])
                
                # 猫庐戮莽陆庐 blast 猫聤聜莽聜鹿氓聫聜忙聲掳
                blast.parm("group").set(f"@{attribute}={value}")
                
                # 忙聽鹿忙聧庐氓卤聜莽潞搂猫庐戮莽陆庐氓聢聠莽禄聞莽卤禄氓聻聥
                if level == "Point":
                    blast.parm("grouptype").set(3)  # 莽聜鹿
                elif level == "Primitive":
                    blast.parm("grouptype").set(4)  # 氓聸戮氓聟聝
                
                blast.parm("negate").set(1)  # 氓聫聧猫陆卢茅聙聣忙聥漏茂录聢盲驴聺莽聲聶氓聦鹿茅聟聧莽職聞茂录聣
                
                # 忙路禄氓聤聽忙鲁篓茅聡聤猫炉麓忙聵聨
                blast.setComment(f"盲驴聺莽聲聶 {attribute} = {value}")
            hou.ui.setStatusMessage(f"芒聹聰氓聢聠莽娄禄忙聢聬氓聤聼茂录聦氓聟卤{i}盲赂陋氓炉鹿猫卤隆", hou.severityType.ImportantMessage)
            # 猫聡陋氓聤篓氓赂聝氓卤聙猫聤聜莽聜鹿
            #parent.layoutChildren()

# 氓聹篓Houdini盲赂颅猫掳聝莽聰篓
create_attribute_split_tool()]]></script>
  </tool>
</shelfDocument>
