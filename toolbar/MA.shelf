    <script scriptType="python"><![CDATA[# === MA_ShelfTools_Pro: kwargs-aware positioning ===
_K8s_REQUESTED = {}  # requested_name â actual nodeï¼å¤çéå½ååºæ¯ï¼
_K8s_REL_POS = {
    "null1": (0, 0),
    "mantra1": (-0.243204578, 1.38769671)
}  # name â (dx, dy) ç¸å¯¹ä½ç½®åç§»ï¼ç±»ä¼¼ $arg2/arg3ï¼
_K8s_PARENT_CATEGORY = "Driver"  # ä¿å­æ¶çç¶çº§ç½ç»ç±»åï¼ç¨äºä¸ä¸æå¼å®¹æ§æ ¡éªï¼
_kwargs = globals().get("kwargs", {})
_pane = _kwargs.get("pane")

# Override hou_parent to current context instead of asCode's hardcoded path.
